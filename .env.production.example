# Smart AI Interior Designer - PRODUCTION Environment
# Copy to .env.production and fill in real values
# NEVER commit .env.production to version control

ENVIRONMENT=production
DEBUG=false

# Generate with: openssl rand -hex 32
SECRET_KEY=

# Database (use strong credentials)
POSTGRES_USER=smart_interior_prod
POSTGRES_PASSWORD=
POSTGRES_DB=smart_interior_prod
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@database:5432/${POSTGRES_DB}

# Redis (set a strong password)
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# MinIO (use strong credentials)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# Internal endpoint used by backend/AI containers inside the docker network.
MINIO_ENDPOINT=minio:9000
# Public endpoint that external clients (browser / phone) use to reach MinIO.
# REQUIRED in production: without it, clients receive unreachable internal
# minio:9000 URLs. Point this at your public storage host (behind TLS).
MINIO_PUBLIC_ENDPOINT=storage.yourdomain.com

# CORS (your production domain)
CORS_ALLOWED_ORIGINS=["https://yourdomain.com"]

# AI Service
AI_SERVICE_URL=http://ai-service:8001

# LLM API Keys
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model Configuration
MODEL_CACHE_DIR=/models
