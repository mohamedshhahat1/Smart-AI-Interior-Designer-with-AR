# Smart AI Interior Designer - Environment Variables

# Environment: development | production | testing
ENVIRONMENT=development

# Backend Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smart_interior
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
SECRET_KEY=dev-only-insecure-key-do-not-use-in-production
DEBUG=true

# Database Credentials (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smart_interior

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# AI Service
AI_SERVICE_URL=http://localhost:8001

# CORS (comma-separated list for production)
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# LLM API Keys (at least one required for AI assistant)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Model Configuration
MODEL_CACHE_DIR=/models
STABLE_DIFFUSION_MODEL=stable-diffusion-v1-5/stable-diffusion-v1-5
STABLE_DIFFUSION_INPAINT_MODEL=stable-diffusion-v1-5/stable-diffusion-inpainting
CONTROLNET_MODEL=lllyasviel/control_v11p_sd15_canny
AI_FORCE_FULL_PRECISION=auto
